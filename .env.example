# Configuración de Django
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=un-secret-key-muy-seguro-para-produccion
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,despliegue-proyecto-1-37u9.onrender.com
CSRF_TRUSTED_ORIGINS=https://despliegue-proyecto-1-37u9.onrender.com

# Ruta personalizada opcional para la BD SQLite (útil en Render si montas un disco persistente)
# Ejemplo para Render con disco montado en /data:
# SQLITE_DB_PATH=/data/db.sqlite3
SQLITE_DB_PATH=

# Configuración de Superusuario por defecto (se crea automáticamente en startup si están definidos)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin-password-secure

# APIs externas (opcional)
GROQ_API_KEY=

# Configuración de Email SMTP (opcional para desarrollo, obligatorio para producción)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=tu-contraseña-de-aplicación
DEFAULT_FROM_EMAIL=no-reply@tu-dominio.com
EMAIL_TIMEOUT=10
